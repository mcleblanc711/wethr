[Unit]
Description=Wethr daily observations, settlement, and reconciliation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/projects/wethr/collector
Environment=WETHR_LIVE=0
ExecStart=%h/projects/wethr/collector/.venv/bin/python %h/projects/wethr/collector/scripts/daily_calibration.py
